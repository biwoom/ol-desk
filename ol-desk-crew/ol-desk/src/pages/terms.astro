---
import "../styles/global.css";
import AppShell from "../components/AppShell.astro";
import { getProjectIds, loadProjectTerms } from "../lib/content-asset";
import { resolveProjectId } from "../lib/app-state";

const projects = await getProjectIds();
const projectId = resolveProjectId(projects, Astro.url.searchParams.get("project"));

if (!projectId) {
  throw new Error("No Contents-Asset projects found.");
}

const terms = await loadProjectTerms(projectId);
const savedState = Astro.url.searchParams.get("saved");
---

<AppShell title="OL-DESK · 용어" projectId={projectId} projects={projects} activeMenu="terms">
  <section slot="hero" class="ol-card">
    <div class="ol-desk-panel-head">
      <div>
        <div class="ol-kicker">Terms</div>
        <h1>용어 후보</h1>
        <p>번역 일관성에 영향을 주는 용어를 승인, 보류, 반려합니다.</p>
      </div>
      <div class="ol-desk-chip-row">
        <span class="ol-badge">terms {terms.length}</span>
      </div>
    </div>
  </section>

  <section class="ol-card">
    {savedState === "term" && <div class="ol-desk-flash">용어 상태를 저장했습니다.</div>}
    <details class="ol-desk-side-panel ol-desk-add-panel-block">
      <summary>신규 용어 추가</summary>
      <form method="post" action="/api/review/term" class="ol-desk-inline-form">
        <input type="hidden" name="projectId" value={projectId} />
        <input type="hidden" name="returnTo" value={`/terms?project=${projectId}`} />
        <label>
          문서 ID
          <input type="text" name="docId" placeholder="gcb-src-004-salutation-and-intention" />
        </label>
        <label>
          원어
          <input type="text" name="sourceTerm" placeholder="dukkha" />
        </label>
        <label>
          언어
          <input type="text" name="sourceLanguage" value="pali" />
        </label>
        <label>
          번역안
          <input type="text" name="translation" placeholder="괴로움" />
        </label>
        <label>
          대안
          <input type="text" name="alternatives" placeholder="고통, 불만족" />
        </label>
        <label>
          메모
          <textarea name="usageNote" placeholder="프로젝트 전체 사용 기준을 적습니다."></textarea>
        </label>
        <label>
          상태
          <select name="status">
            {["candidate", "approved", "hold"].map((status) => (
              <option value={status}>{status}</option>
            ))}
          </select>
        </label>
        <button class="ol-btn ol-btn-sm ol-btn-outline" type="submit">용어 추가</button>
      </form>
    </details>
    {terms.length > 0 ? (
      <div class="ol-desk-table-wrap">
        <table class="ol-desk-table">
          <thead>
            <tr>
              <th>원어</th>
              <th>번역안</th>
              <th>상태</th>
              <th>대안</th>
              <th>문서</th>
              <th>메모</th>
              <th>편집</th>
            </tr>
          </thead>
          <tbody>
            {terms.map((term) => (
              <tr>
                <td>
                  <strong>{term.sourceTerm}</strong>
                  <div class="ol-brand-meta">{term.sourceLanguage}</div>
                </td>
                <td>{term.translation}</td>
                <td><span class="ol-badge">{term.status}</span></td>
                <td>{term.alternatives.join(", ") || "-"}</td>
                <td><a href={`/translation/${term.firstDocId}?project=${projectId}`}>{term.firstDocId}</a></td>
                <td>{term.usageNote || "-"}</td>
                <td>
                  <form method="post" action="/api/review/term" class="ol-desk-inline-form ol-desk-inline-form-tight">
                    <input type="hidden" name="projectId" value={projectId} />
                    <input type="hidden" name="termId" value={term.termId} />
                    <input type="hidden" name="returnTo" value={`/terms?project=${projectId}`} />
                    <label>
                      상태
                      <select name="status">
                        {["candidate", "approved", "hold", "rejected", "deprecated"].map((status) => (
                          <option value={status} selected={status === term.status}>{status}</option>
                        ))}
                      </select>
                    </label>
                    <button class="ol-btn ol-btn-sm ol-btn-outline" type="submit">저장</button>
                  </form>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="ol-desk-empty">용어 데이터가 없습니다.</div>
    )}
  </section>
</AppShell>
