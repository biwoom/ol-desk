---
import "../styles/global.css";
import AppShell from "../components/AppShell.astro";
import { getProjectIds, loadProjectDashboard } from "../lib/content-asset";
import { resolveProjectId } from "../lib/app-state";

const projects = await getProjectIds();
const projectId = resolveProjectId(projects, Astro.url.searchParams.get("project"));

if (!projectId) {
  throw new Error("No Contents-Asset projects found.");
}

const dashboard = await loadProjectDashboard(projectId);
const highlighted = dashboard.documents
  .filter((document) =>
    document.currentStatus === "human_editing" ||
    document.currentStatus === "draft3_handoff_ready" ||
    document.assets.draft2 ||
    document.riskIssues.length > 0
  )
  .slice(0, 6);
const humanQueue = dashboard.documents.filter((document) =>
  document.currentStatus === "human_editing" ||
  document.currentStatus === "draft3_handoff_ready" ||
  document.assets.draft2
);
const riskQueue = dashboard.documents.filter((document) => document.riskIssues.length > 0 || document.provenanceIssues.length > 0);
---

<AppShell title="OL-DESK" projectId={projectId} projects={projects} activeMenu="overview">
  <section slot="hero" class="ol-card">
    <div class="ol-desk-panel-head">
      <div>
        <div class="ol-kicker">Review Desk</div>
        <h1>{dashboard.summary.projectTitle}</h1>
        <p>
          오늘 감수자가 확인해야 할 문서, 수정 가능한 원고, 보류 판단을 한 화면에서 시작합니다.
        </p>
      </div>
      <div class="ol-desk-chip-row">
        <span class="ol-badge">Updated {dashboard.summary.updatedAt.slice(0, 10)}</span>
        <span class="ol-badge">Issues {Object.keys(dashboard.summary.issueCounts).length}</span>
        <span class="ol-badge">Parse errors {dashboard.summary.parseErrors.length}</span>
        <span class="ol-badge">Draft3 handoff {dashboard.summary.handoffDraft3Count}</span>
      </div>
    </div>
    <div class="ol-desk-stat-grid">
      <div class="ol-desk-stat">
        <div class="ol-mono-label">전체 문서</div>
        <div class="ol-desk-stat-value">{dashboard.summary.documentCount}</div>
      </div>
      <div class="ol-desk-stat">
        <div class="ol-mono-label">감수 가능</div>
        <div class="ol-desk-stat-value">{humanQueue.length}</div>
      </div>
      <div class="ol-desk-stat">
        <div class="ol-mono-label">2차 원고</div>
        <div class="ol-desk-stat-value">{dashboard.summary.draft2Count}</div>
      </div>
      <div class="ol-desk-stat">
        <div class="ol-mono-label">3차 전달</div>
        <div class="ol-desk-stat-value">{dashboard.summary.handoffDraft3Count}</div>
      </div>
      <div class="ol-desk-stat">
        <div class="ol-mono-label">주의 필요</div>
        <div class="ol-desk-stat-value">{riskQueue.length}</div>
      </div>
      <div class="ol-desk-stat">
        <div class="ol-mono-label">기록된 이슈</div>
        <div class="ol-desk-stat-value">{Object.values(dashboard.summary.issueCounts).reduce((sum, count) => sum + count, 0)}</div>
      </div>
    </div>
  </section>

  <div class="ol-desk-grid">
    <div class="ol-desk-stack">
      <section class="ol-card">
        <div class="ol-desk-panel-head">
          <div>
            <h2>주요 작업</h2>
            <p>감수자가 자주 쓰는 화면을 우선 배치했습니다.</p>
          </div>
        </div>
        <div class="ol-desk-artifact-list">
          <a class="ol-desk-artifact ol-desk-linkcard" href={`/progress?project=${projectId}`}>
            <strong>진행</strong>
            <span>문서 큐와 다음 작업 확인</span>
          </a>
          <a class="ol-desk-artifact ol-desk-linkcard" href={`/translation?project=${projectId}`}>
            <strong>번역</strong>
            <span>원고 비교, 3차/4차 수정, 용어·각주 판단</span>
          </a>
          <a class="ol-desk-artifact ol-desk-linkcard" href={`/terms?project=${projectId}`}>
            <strong>용어</strong>
            <span>용어 후보 승인, 보류, 반려</span>
          </a>
          <a class="ol-desk-artifact ol-desk-linkcard" href={`/annotations?project=${projectId}`}>
            <strong>각주</strong>
            <span>각주 후보 정리와 본문 연결</span>
          </a>
          <a class="ol-desk-artifact ol-desk-linkcard" href={`/crew?project=${projectId}`}>
            <strong>작업기록</strong>
            <span>에이전트 작업 기록 확인</span>
          </a>
          <a class="ol-desk-artifact ol-desk-linkcard" href={`/admin?project=${projectId}`}>
            <strong>관리</strong>
            <span>데이터 오류, export, 최종 이력 점검</span>
          </a>
        </div>
      </section>

      <section class="ol-card">
        <div class="ol-desk-panel-head">
          <div>
            <h2>바로 이어서 볼 문서</h2>
            <p>수정 가능하거나 확인이 필요한 문서를 먼저 보여줍니다.</p>
          </div>
        </div>
        <div class="ol-desk-risk-list">
          {highlighted.map((document) => (
            <article class="ol-desk-risk-item">
              <div class="ol-desk-log-meta">
                <span class="ol-badge">{document.docId}</span>
                {document.assets.normalized && <span class="ol-badge">normalized</span>}
                {document.assets.draft1 && <span class="ol-badge">draft1</span>}
                {document.assets.draft2 && <span class="ol-badge">draft2</span>}
              </div>
              <strong>{document.title}</strong>
              <p>{document.nextAction || "next action 없음"}</p>
            </article>
          ))}
        </div>
      </section>
    </div>

    <aside class="ol-desk-stack">
      <section class="ol-card ol-card-tight">
        <div class="ol-desk-panel-head">
          <div>
            <h3>작업 흐름</h3>
            <p>대부분의 감수 작업은 번역 화면에서 끝내고, 관리 화면은 이상 징후 확인에만 사용합니다.</p>
          </div>
        </div>
        <div class="ol-desk-risk-list">
          <article class="ol-desk-risk-item">
            <strong>1. 진행에서 문서 선택</strong>
            <p>상태와 다음 작업을 확인한 뒤 번역 화면으로 이동합니다.</p>
          </article>
          <article class="ol-desk-risk-item">
            <strong>2. 번역 화면에서 판단</strong>
            <p>원고 비교, 용어/각주/태그, 메모, handoff를 같은 흐름에서 처리합니다.</p>
          </article>
        </div>
      </section>
    </aside>
  </div>
</AppShell>
